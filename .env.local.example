# ─── Frontend (prefijo VITE_ = públicas, van al bundle) ────────────────────────

# Google Maps API Key — habilitar: Maps JS API + Geocoding API
VITE_GOOGLE_MAPS_API_KEY=TODO

# Google OAuth Client ID (mismo que GOOGLE_CLIENT_ID abajo)
VITE_GOOGLE_CLIENT_ID=TODO

# Emails de admin para UI (controla si se muestra el botón de sync)
# Separados por coma, sin espacios
VITE_ADMIN_EMAILS=jorge@moradauno.com

# URL base de la API (vacío = mismo dominio, correcto para Vercel)
VITE_API_URL=


# ─── Backend / Build (NO prefijo VITE_ = privadas, solo servidor) ──────────────

# ID del Google Sheet de cobertura (el que ya tenemos)
GOOGLE_SHEETS_ID=1f8tD_Skl7Z2BXgwy6ESwQxot2VaVOe_h

# Credenciales de Service Account (elige UNA de las dos opciones):

# Opción A — JSON como string (recomendada para Vercel: Settings > Env Vars)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# Opción B — Ruta al archivo local (para desarrollo)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.key.json

# Google OAuth Client ID (para validar tokens en el API)
GOOGLE_CLIENT_ID=TODO

# Emails autorizados como admin (validación real en el servidor)
ADMIN_EMAILS=jorge@moradauno.com

# Vercel Deploy Hook URL — Settings > Git > Deploy Hooks en tu proyecto Vercel
VERCEL_DEPLOY_HOOK_URL=TODO

# Dominio de producción (para CORS)
ALLOWED_ORIGIN=https://verificador-cobertura.vercel.app
